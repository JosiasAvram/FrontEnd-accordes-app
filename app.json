{
  "expo": {
    "name": "Letras y Acordes",
    "slug": "letras-y-acordes",
    "version": "4.6.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF3E0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.josi.letrasyacordes",
      "buildNumber": "11"
    },
    "android": {
      "package": "com.josi.letrasyacordes",
      "versionCode": 11,
      "softwareKeyboardLayoutMode": "pan",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FAF3E0"
      }
    },
    "extra": {
      "apiUrl": "https://accordes-app-backend.onrender.com/api/v1",
      "eas": {
        "projectId": "5b577518-c93e-49a5-b4a7-8f068127f80c"
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#F59E0B",
          "defaultChannel": "default"
        }
      ]
    ],
    "owner": "josiasavram"
  }
}
